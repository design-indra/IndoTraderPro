# ════════════════════════════════════════════════════════
#   IndoTrader Pro v4 — Environment Variables
#   Copy file ini menjadi .env.local untuk development
# ════════════════════════════════════════════════════════

# ── Supabase (WAJIB) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ── JWT Secret (GANTI dengan string acak panjang!) ────────
JWT_SECRET=ganti-dengan-random-string-panjang-minimal-32-karakter

# ── Indodax API (untuk Live Mode) ────────────────────────
INDODAX_API_KEY=your_api_key_here
INDODAX_SECRET_KEY=your_secret_key_here

# ── Demo Mode Balance Awal (IDR) ─────────────────────────
DEMO_BALANCE=100000

# ── Bot Risk Settings ─────────────────────────────────────
MAX_POSITIONS=1
MAX_RISK_PERCENT=40
STOP_LOSS_PERCENT=1.0
TAKE_PROFIT_PERCENT=2.5
TRAILING_STOP_PERCENT=0.5
MAX_CONSECUTIVE_LOSSES=3

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.railway.app
NODE_ENV=production
